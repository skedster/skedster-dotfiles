[colors]
background     = ${xrdb:color0:#090E13}
background-alt = ${xrdb:color4:#89b4fa}
foreground     = ${xrdb:color7:#cdd6f4}
primary        = ${xrdb:color5:#cba6f7}
secondary      = ${xrdb:color2:#181825}
alert          = ${xrdb:color1:#f38ba8}
disabled       = ${xrdb:color8:#bac2de}

base = #1e1e2e
mantle = #181825
crust = #11111b
text = #cdd6f4
subtext0 = #a6adc8
subtext1 = #bac2de
surface0 = #313244
surface1 = #45475a
surface2 = #585b70
overlay0 = #6c7086
overlay1 = #7f849c
overlay2 = #9399b2
blue = #89b4fa
lavender = #b4befe
sapphire = #74c7ec
sky = #89dceb
teal = #94e2d5
green = #a6e3a1
yellow = #f9e2af
peach = #fab387
maroon = #eba0ac
red = #f38ba8
mauve = #cba6f7
pink = #f5c2e7
flamingo = #f2cdcd
rosewater = #f5e0dc
transparent = #00000000

[bar/example]
width = 100% 
height = 20pt 
radius = 8
dpi = 0 
background = ${colors.background} 
foreground = ${colors.foreground} 
line-size = 2pt 
border-left-size = 12pt
border-right-size = 12pt
border-top-size = 4pt
border-color = #00000000 
padding-left = 2 
padding-right = 2 
module-margin = 1 
separator = | 
separator-foreground = ${colors.disabled} 
font-0 = JetBrainsMono Nerd Font:style=Bold:pixelsize=14;3 
font-1 = "Noto Color Emoji:pixelsize=16:style=Regular:scale=10;2" 
font-2 = Material Design Icons:style=Bold:size=13;3 
modules-left = i3 weather backlight pulseaudio
modules-center = date
modules-right = tray memory cpu temperature battery network
cursor-click = pointer 
cursor-scroll = ns-resize

[module/tray]
type = internal/tray
tray-spacing = 8px

[module/pulseaudio]
type = internal/pulseaudio
ramp-volume-foreground = ${colors.primary}
format-volume = <ramp-volume>  <label-volume>
ramp-volume-0 = 
ramp-volume-1 = 
label-volume = "%{A1:pavucontrol &:}%percentage%%%{A}"
label-muted = muted
label-muted-foreground = ${colors.disabled}

[module/temperature]
type = internal/temperature
interval = 12
zone-type = TCPU
warn-temperature = 60
format = "%{A1:exec xsensors:}<ramp> <label>%{A}"
format-warn = <ramp> <label-warn>
format-padding = 0
label = "%temperature-c%"
label-warn = %temperature-c%
ramp-0 = ""
ramp-1 = ""
ramp-2 = ""
ramp-3 = ""
ramp-4 = ""
ramp-foreground = ${colors.primary}

[module/weather]
type = custom/script
exec = curl -s 'wttr.in/giza?format=%t+%c' | awk '{gsub(/\+/, " "); gsub(/️/, ""); print $2, $1}'
interval = 3600
click-left = "exec gnome-weather"

[module/backlight]
type = internal/backlight
enable-scroll = true
format = <ramp> <label>
ramp-foreground = ${colors.primary}
ramp-0 = 🌕
ramp-1 = 🌔
ramp-2 = 🌓
ramp-3 = 🌒
ramp-4 = 🌑

[module/memory]
type = internal/memory
interval = 8
format = "%{A1:exec wezterm -e btop:}<ramp-used> <label>%{A}"
ramp-used-0 = " "
ramp-used-foreground = ${colors.primary}
label = %used%

[module/cpu]
type = internal/cpu
interval = 5
format = "%{A1:exec wezterm -e btop:}<ramp-load> <label>%{A}"
label = "%percentage%%"
ramp-load-0 = "󰍛"
ramp-load-foreground = ${colors.primary}

[module/network]
type = internal/network
interval = 10
interface-type = wireless
format-connected = <label-connected>
label-connected = "%{A1:wezterm start --class wifi-float -e nmtui:}󰖩 %{A}"
label-connected-foreground = ${colors.primary}
format-disconnected = <label-disconnected>
label-disconnected = "%{A1:wezterm start --class wifi-float -e nmtui:}󰖪 %{A}"
label-disconnected-foreground = ${colors.alert}

[module/date]
type = custom/script
interval = 60
exec = ~/.config/polybar/date.sh
label-foreground = ${colors.primary}
click-left = "exec gnome-calendar"

[module/battery]
type = internal/battery
poll-interval = 15
battery = BAT0
adapter = AC0
format-charging = <ramp-capacity>󱐋 <label-charging>
label-charging = %percentage%%
format-charging-padding = 0
format-discharging = <ramp-capacity> <label-discharging>
label-discharging = %percentage%%
format-discharging-foreground = ${colors.foreground}
format-full-prefix = " "
format-full-prefix-foreground = #A0E8A2
format-foreground = ${colors.background-alt}
format-background = #2b2f37
label-discharging-foreground = ${colors.foreground}
ramp-capacity-foreground = ${colors.primary}
label-charging-foreground = ${colors.foreground}
ramp-capacity-0 = " "
ramp-capacity-1 = " "
ramp-capacity-2 = " "
ramp-capacity-3 = " "
ramp-capacity-4 = " "
format-discharging-padding = 0

[module/prayers]
type = custom/script
interval = 60
label = %{F#cba6f7} %{F-} %output%%{A}

[settings]
screenchange-reload = true
pseudo-transparency = true

[module/i3]
type = internal/i3
pin-workspaces = true
enable-click = true
enable-scroll = false
format = <label-state> <label-mode>
label-focused = %name%
label-focused-background = ${colors.background-alt}
label-focused-underline = ${colors.primary}
label-focused-padding = 1
label-unfocused = %name%
label-unfocused-padding = 1
label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 1
label-visible = %name%
label-visible-padding = 1
